{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "cli": {
    "packageManager": "npm",
    "analytics": false
  },
  "newProjectRoot": "projects",
  "projects": {
    "chatbox": {
      "projectType": "application",
      "schematics": {},
      "root": "projects/chatbox",
      "sourceRoot": "projects/chatbox/src",
      "prefix": "app",
      "architect": {
        "build": {
          "builder": "@angular/build:application",
          "options": {
            "browser": "projects/chatbox/src/main.ts",
            "tsConfig": "projects/chatbox/tsconfig.app.json",
            "assets": [
              {
                "glob": "**/*",
                "input": "projects/chatbox/public"
              }
            ],
            "styles": [
              "projects/chatbox/src/styles.css"
            ]
          },
          "configurations": {
            "production": {
              "optimization": {
                "fonts": false
              },
              "budgets": [
                {
                  "type": "initial",
                  "maximumWarning": "500kB",
                  "maximumError": "1MB"
                },
                {
                  "type": "anyComponentStyle",
                  "maximumWarning": "20kB",
                  "maximumError": "32kB"
                }
              ],
              "outputHashing": "all",
              "fileReplacements": [
                {
                  "replace": "projects/chatbox/src/environments/environment.ts",
                  "with": "projects/chatbox/src/environments/environment.prod.ts"
                }
              ]
            },
            "development": {
              "optimization": false,
              "extractLicenses": false,
              "sourceMap": true
            }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular/build:dev-server",
          "configurations": {
            "production": {
              "buildTarget": "chatbox:build:production"
            },
            "development": {
              "buildTarget": "chatbox:build:development"
            }
          },
          "defaultConfiguration": "development"
        },
        "test": {
          "builder": "@angular/build:unit-test"
        }
      }
    }
  }
}
